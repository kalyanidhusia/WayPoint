{
  "name": "waypoint-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:build": "PAGES_BASE_PATH=/WayPoint next build",
    "pages:serve": "mkdir -p .pages-preview && ln -sfn ../out .pages-preview/WayPoint && serve .pages-preview",
    "start": "serve out",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude '**/*evals.test.ts'",
    "evals": "vitest run src/lib/waypoint/evals.test.ts src/lib/waypoint/companion-evals.test.ts"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@zxing/library": "^0.23.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "qrcode": "^1.5.4",
    "serve": "^14.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
